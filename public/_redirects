# Redirects for Netlify
# Ensure favicon and other assets are served correctly
/favicon.ico /icon.png 200
/icon.ico /icon.png 200

# Next.js on Netlify handles routing via @netlify/plugin-nextjs — no static catch-all needed

# Security headers
/*
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
